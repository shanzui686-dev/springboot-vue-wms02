# ==========================================
# 后端 (Spring Boot / Maven / Java)
# ==========================================
# 忽略编译和打包生成的 target 目录
target/
wms/target/
*.class

# 忽略日志文件
*.log

# 忽略打包文件 (根据需要，如果你需要提交 jar 包请注释掉)
*.jar
*.war
*.ear

# Maven 包装器 jar 包 (一般只提交 properties，不提交 jar)
.mvn/wrapper/maven-wrapper.jar

# ==========================================
# 前端 (Vue / Node.js)
# ==========================================
# 忽略依赖包目录 (必须忽略，否则会导致仓库极其庞大)
node_modules/
workspace/node_modules/

# 忽略打包生成的 dist 目录
dist/
workspace/dist/

# 忽略 npm/yarn/pnpm 的报错日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# 忽略本地环境变量文件
.env.local
.env.*.local

# 忽略 eslint 缓存
.eslintcache
workspace/.eslintcache

# ==========================================
# IDE 配置文件 (IntelliJ IDEA, VSCode 等)
# ==========================================
# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws

# VSCode
.vscode/

# Eclipse
.settings/
.classpath
.project

# ==========================================
# 操作系统生成文件
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini